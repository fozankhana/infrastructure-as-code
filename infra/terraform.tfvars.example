# Copy this file to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars — it may contain secrets.

project_name = "myapp"
environment  = "dev"          # dev | staging | prod
aws_region   = "us-east-1"
owner_email  = "team@example.com"

vpc_cidr           = "10.1.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b", "us-east-1c"]

instance_type     = "t3.small"
db_instance_class = "db.t3.micro"

app_version = "latest"

# Sensitive — pass via environment variable or CI secret, not this file:
# db_password = "CHANGE_ME"

# ACM certificate ARN for the HTTPS listener (must already exist in AWS):
# acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/..."

# S3 bucket for ALB access logs (must already exist):
# log_bucket = "my-company-logs"
